<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/pages_background"
    tools:context=".AddFoodActivity">

    <TextView
        android:id="@+id/add_food_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="24dp"
        android:textColor="@color/white"
        android:textSize="24sp"
        android:textStyle="bold"
        tools:text="Add to Breakfast" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/food_list_recycler"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/add_food_title"
        android:layout_above="@+id/save_food_btn"
        android:padding="16dp" />

    <Button
        android:id="@+id/save_food_btn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_margin="16dp"
        android:backgroundTint="@color/white"
        android:padding="16dp"
        android:text="Add Selected Items"
        android:textColor="@color/black"
        android:textSize="18sp" />

</RelativeLayout>
